# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# =========================
# App
# =========================
VITE_APP_NAME=ChannelForgeAI
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173

# =========================
# n8n / automation
# Use the PRODUCTION webhook URL for real integrations
# Do not put secrets in VITE_* vars
# =========================
VITE_N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/channelforge-dispatch
VITE_N8N_TIMEOUT_MS=30000

# =========================
# Feature flags
# Use "true" / "false"
# =========================
VITE_ENABLE_AUTOMATION=true
VITE_ENABLE_ROUGH_CUTS=true
VITE_ENABLE_PUBLISH_CENTER=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SHORTS=true
VITE_ENABLE_N8N_WEBHOOKS=true
VITE_ENABLE_MANUAL_ANALYTICS_ENTRY=true